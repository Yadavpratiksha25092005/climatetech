# Copy this file to .env in the same directory (next to docker-compose.yml)
# and fill in real values. .env is gitignored — never commit real secrets.
#
# Run with: docker compose up -d --build

# Postgres container init (consumed by the postgres service)
POSTGRES_USER=climatetech
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=climatetech_db

# Backend — server
# NOTE: this file is for the local docker-compose stack, where Postgres runs
# without TLS and is reached over the compose network — that's fine for
# local dev but is NOT a valid production posture. Set APP_ENV=production
# (and DB_SSLMODE=require/verify-full, and a real ALLOWED_ORIGINS) only when
# actually deploying against a TLS-terminated RDS instance; the app now
# refuses to start with APP_ENV=production and DB_SSLMODE=disable together,
# and refuses ALLOWED_ORIGINS containing "*".
APP_ENV=development
APP_PORT=8080

# Backend — database (DB_HOST must stay "postgres" — the in-network service
# name — when running via docker-compose; only change it for a different
# deployment topology)
DB_HOST=postgres
DB_PORT=5432
DB_USER=climatetech
# Required — the app now refuses to start if this is missing/empty.
DB_PASSWORD=
DB_NAME=climatetech_db
DB_SSLMODE=disable

# Backend — redis. Set a real REDIS_PASSWORD for anything beyond a laptop —
# docker-compose's redis service is configured to require this same value.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend — JWT. Required — the app now refuses to start if either is
# missing or empty. Generate real random values, e.g.:
#   openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Backend — CORS (comma-separated list of allowed origins). Must never
# contain "*" — CORS is configured with credentials enabled, and the app
# refuses to start if a wildcard origin is set.
ALLOWED_ORIGINS=http://localhost:5000

# Backend — comma-separated CIDRs of trusted upstream proxies/load balancers,
# for correct client-IP resolution (X-Forwarded-For) behind an ALB. Leave
# empty for local dev (no proxy in front); set to the ALB's subnet in AWS.
TRUSTED_PROXIES=

# Backend — third-party APIs
OPENWEATHER_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
NEWS_API_KEY=

# Backend — Firebase Cloud Messaging (push notifications). Download a
# service-account JSON from Firebase console > Project settings > Service
# accounts, save it as backend/firebase-service-account.json (gitignored —
# never commit it). docker-compose mounts that file into the container at
# runtime at the path below; leave this value as-is.
FIREBASE_CREDENTIALS_PATH=/app/firebase-service-account.json
