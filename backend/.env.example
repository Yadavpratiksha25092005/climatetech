# Server
APP_ENV=development
APP_PORT=8080

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=climatetech
# Required — the app now refuses to start if this is missing/empty.
DB_PASSWORD=
DB_NAME=climatetech_db
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — required, the app now refuses to start if either is missing/empty.
# This file is NOT baked into the Docker image (see backend/Dockerfile) —
# it's local-dev-only documentation/reference. Never put real secrets here.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# CORS — must never contain "*"; the app refuses to start with a wildcard
# origin since CORS is configured with credentials enabled.
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# Comma-separated CIDRs of trusted upstream proxies/load balancers. Leave
# empty for local dev; set to the ALB's subnet in AWS so client IPs
# (X-Forwarded-For) used by rate limiting/logging can't be spoofed.
TRUSTED_PROXIES=

# News feed
NEWS_API_KEY=

# Weather / AI
OPENWEATHER_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Firebase Cloud Messaging (push notifications) — path to a service account
# JSON downloaded from Firebase console > Project settings > Service accounts.
# Never commit the actual file; leave unset to disable push notifications.
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
